# Database (PostgreSQL / Supabase)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# Session Security (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET="generate-a-random-32-byte-hex-string-here"

# Application
NODE_ENV="production"
NEXT_PUBLIC_URL="https://your-domain.com"

# Optional: HuggingFace API (for AI features)
HUGGINGFACE_API_KEY="hf_your_key_here"
